# Base URL for the Chat UI
CLAUSY_PROVIDER=chatgpt
# Auto-route requests by incoming model id (e.g. claude-web -> claude, openai-api -> openai)
CLAUSY_AUTO_MODEL_SWITCH=1
# Optional fallback chain when selected provider fails (comma-separated): local -> cloud -> backup
# Example: CLAUSY_FALLBACK_CHAIN=ollama,openai,openrouter
CLAUSY_FALLBACK_CHAIN=
# Optional: reorder primary+fallback candidates by configured provider cost (lowest first)
CLAUSY_COST_AWARE_ROUTING=0
# Comma-separated provider:cost map used when CLAUSY_COST_AWARE_ROUTING=1
# Example: CLAUSY_PROVIDER_COSTS=ollama:0.1,openai:2.0,openrouter:3.5
CLAUSY_PROVIDER_COSTS=

# Browser provider URLs
CLAUSY_CHATGPT_URL=https://chatgpt.com
CLAUSY_CLAUDE_URL=https://claude.ai
CLAUSY_GROK_URL=https://grok.com
CLAUSY_GEMINI_WEB_URL=https://gemini.google.com
CLAUSY_PERPLEXITY_URL=https://www.perplexity.ai
CLAUSY_POE_URL=https://poe.com
CLAUSY_DEEPSEEK_URL=https://chat.deepseek.com

# Optional: allow unauthenticated browser usage when provider pages permit guest mode.
# 0 (default) keeps strict login-required behavior.
ALLOW_ANON_BROWSER=0

# CDP connection to a Chrome instance you control
CLAUSY_CDP_HOST=127.0.0.1
CLAUSY_CDP_PORT=9200
CLAUSY_PROFILE_DIR=./profile
# Optional per-provider profile mapping: provider:path,provider:path
# Example: CLAUSY_PROFILE_BY_PROVIDER=chatgpt:./profile-chatgpt,claude:./profile-claude
CLAUSY_PROFILE_BY_PROVIDER=
# Anti-detection profile rotation (round-robin per provider):
# when enabled and count > 1, Clausy rotates between "<profile>-rot1..rotN".
CLAUSY_PROFILE_ROTATION_ENABLED=0
CLAUSY_PROFILE_ROTATION_COUNT=0
CLAUSY_HEADLESS=0
# Browser bootstrap strategy: auto | always | never
CLAUSY_BROWSER_BOOTSTRAP=auto
# Optional explicit browser binary path (Chrome/Chromium)
CLAUSY_BROWSER_BINARY=
# Extra browser CLI args (space-separated)
CLAUSY_BROWSER_ARGS=
# CDP connect timeout seconds after bootstrap
CLAUSY_CDP_CONNECT_TIMEOUT=20
# Add --no-sandbox for constrained container/runtime setups (0/1)
CLAUSY_CHROME_NO_SANDBOX=0

# Server
CLAUSY_BIND=0.0.0.0
CLAUSY_PORT=3108

# JSON strictness / repair
CLAUSY_MAX_REPAIRS=2

# Session handling
# If set, Clausy reads session id from this HTTP header (default: X-Clausy-Session)
CLAUSY_SESSION_HEADER=X-Clausy-Session

# Optional: API provider mode (OpenAI + Anthropic + Ollama + Gemini + OpenRouter)
# Set CLAUSY_PROVIDER=openai|anthropic|ollama|gemini|openrouter to use API mode instead of browser mode.
CLAUSY_OPENAI_API_KEY=
CLAUSY_OPENAI_BASE_URL=https://api.openai.com/v1
CLAUSY_ANTHROPIC_API_KEY=
CLAUSY_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
CLAUSY_OLLAMA_API_KEY=
CLAUSY_OLLAMA_BASE_URL=http://127.0.0.1:11434
CLAUSY_GEMINI_API_KEY=
CLAUSY_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
CLAUSY_OPENROUTER_API_KEY=
CLAUSY_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
CLAUSY_OPENROUTER_SITE_URL=
CLAUSY_OPENROUTER_APP_NAME=

# Auto reset after N turns per session (summary + fresh chat/tab)
CLAUSY_RESET_TURNS=20
CLAUSY_RESET_SUMMARY_MAX_CHARS=1500
# Optional browser connection restart after N resets (0 disables)
CLAUSY_BROWSER_RESTART_EVERY_RESETS=0
# Optional browser connection restart after N completed requests per session (0 disables)
CLAUSY_BROWSER_RESTART_EVERY_REQUESTS=0

# Optional realtime in-memory event log (GET /v1/events)
CLAUSY_EVENT_LOG_ENABLED=1
CLAUSY_EVENT_LOG_MAX_ITEMS=500

# Optional child-safe / bad-word filtering
CLAUSY_BADWORD_FILTER_MODE=off
CLAUSY_BADWORD_WORDS=
CLAUSY_BADWORD_REPLACEMENT=[CENSORED]
CLAUSY_BADWORD_BLOCK_MESSAGE=Content blocked by safety filter.

# Optional tool-call password gating
CLAUSY_TOOL_PASSWORD=
CLAUSY_TOOL_PASSWORD_HEADER=X-Clausy-Tool-Password
CLAUSY_TOOL_PASSWORD_MESSAGE=Tool execution is password-protected. Provide a valid tool password to continue.

# Optional keyword alerts (email + telegram)
CLAUSY_KEYWORD_ALERTS_ENABLED=0
CLAUSY_KEYWORD_ALERTS_KEYWORDS=token,password,secret
CLAUSY_KEYWORD_ALERTS_CASE_SENSITIVE=0
# bounded: 1..86400
CLAUSY_KEYWORD_ALERTS_WINDOW_SECONDS=300
# bounded: 1..1000
CLAUSY_KEYWORD_ALERTS_MAX_PER_WINDOW=1

CLAUSY_ALERT_TELEGRAM_BOT_TOKEN=
CLAUSY_ALERT_TELEGRAM_CHAT_ID=
CLAUSY_ALERT_TELEGRAM_API_BASE=https://api.telegram.org

CLAUSY_ALERT_EMAIL_SMTP_HOST=
# bounded: 1..65535
CLAUSY_ALERT_EMAIL_SMTP_PORT=587
CLAUSY_ALERT_EMAIL_USERNAME=
CLAUSY_ALERT_EMAIL_PASSWORD=
CLAUSY_ALERT_EMAIL_FROM=
CLAUSY_ALERT_EMAIL_TO=
CLAUSY_ALERT_EMAIL_STARTTLS=1
